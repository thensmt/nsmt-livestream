# Copy this to .env and fill in real values before deploying Lambda functions.
# NEVER commit the filled-in .env to git.

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
AWS_REGION=us-east-1

# DynamoDB table names (defaults already match, override if needed)
DYNAMODB_TABLE_EVENTS=nsmt-events
DYNAMODB_TABLE_TIERS=nsmt-ticket-tiers
DYNAMODB_TABLE_ORDERS=nsmt-orders
DYNAMODB_TABLE_TICKETS=nsmt-tickets
DYNAMODB_TABLE_ORGS=nsmt-orgs

# SES
SES_FROM_ADDRESS=tickets@thensmt.com

# Frontend
FRONTEND_BASE_URL=https://tickets.thensmt.com
ALLOWED_ORIGIN=https://tickets.thensmt.com

# Multi-tenancy
DEFAULT_ORG_ID=nsmt
ALLOWED_ORG_IDS=nsmt
