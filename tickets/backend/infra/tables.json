{
  "Comment": "DynamoDB table definitions for the NSMT ticketing platform. Deploy with: aws cloudformation deploy --template-file tables.yaml --stack-name nsmt-tickets",
  "Tables": [
    {
      "TableName": "nsmt-orgs",
      "BillingMode": "PAY_PER_REQUEST",
      "AttributeDefinitions": [
        { "AttributeName": "orgId", "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "orgId", "KeyType": "HASH" }
      ],
      "Notes": "One item per tenant org. Seed with { orgId: 'nsmt', displayName: 'Nova Sports Media Team', primaryColor: '#0E80FC', logoUrl: '...', stripeAccountId: null, customDomain: 'tickets.thensmt.com' }"
    },
    {
      "TableName": "nsmt-events",
      "BillingMode": "PAY_PER_REQUEST",
      "AttributeDefinitions": [
        { "AttributeName": "orgId",   "AttributeType": "S" },
        { "AttributeName": "eventId", "AttributeType": "S" },
        { "AttributeName": "slug",    "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "orgId",   "KeyType": "HASH" },
        { "AttributeName": "eventId", "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "slug-index",
          "KeySchema": [
            { "AttributeName": "orgId", "KeyType": "HASH" },
            { "AttributeName": "slug",  "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "ItemShape": {
        "orgId": "nsmt",
        "eventId": "evt_<id>",
        "title": "Hoopfest 2026",
        "slug": "hoopfest-2026",
        "description": "...",
        "startDateTime": "2026-03-22T10:00:00-05:00",
        "endDateTime": "2026-03-22T20:00:00-05:00",
        "venue": { "name": "", "address": "", "city": "", "state": "", "zip": "", "mapUrl": "" },
        "status": "draft | published | cancelled | ended",
        "coverImageUrl": "",
        "capacity": 0,
        "ticketsSold": 0,
        "promoCodes": [
          { "code": "NSMT10", "discountType": "percent | fixed", "discountValue": 10, "maxUses": 100, "usesCount": 0 }
        ],
        "createdAt": "",
        "updatedAt": ""
      }
    },
    {
      "TableName": "nsmt-ticket-tiers",
      "BillingMode": "PAY_PER_REQUEST",
      "AttributeDefinitions": [
        { "AttributeName": "eventId", "AttributeType": "S" },
        { "AttributeName": "tierId",  "AttributeType": "S" },
        { "AttributeName": "orgId",   "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "eventId", "KeyType": "HASH" },
        { "AttributeName": "tierId",  "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "orgId-eventId-index",
          "KeySchema": [
            { "AttributeName": "orgId",   "KeyType": "HASH" },
            { "AttributeName": "eventId", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "ItemShape": {
        "eventId": "evt_<id>",
        "tierId": "tier_<id>",
        "orgId": "nsmt",
        "name": "General Admission",
        "description": "Floor access",
        "price": 1500,
        "capacity": 0,
        "sold": 0,
        "sortOrder": 0,
        "active": true
      }
    },
    {
      "TableName": "nsmt-orders",
      "BillingMode": "PAY_PER_REQUEST",
      "AttributeDefinitions": [
        { "AttributeName": "orderId",    "AttributeType": "S" },
        { "AttributeName": "orgId",      "AttributeType": "S" },
        { "AttributeName": "buyerEmail", "AttributeType": "S" },
        { "AttributeName": "eventId",    "AttributeType": "S" },
        { "AttributeName": "createdAt",  "AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "orderId", "KeyType": "HASH" },
        { "AttributeName": "orgId",   "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "email-index",
          "KeySchema": [
            { "AttributeName": "buyerEmail", "KeyType": "HASH" },
            { "AttributeName": "createdAt",  "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        },
        {
          "IndexName": "event-index",
          "KeySchema": [
            { "AttributeName": "eventId",   "KeyType": "HASH" },
            { "AttributeName": "createdAt", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "ItemShape": {
        "orderId": "ord_<id>",
        "orgId": "nsmt",
        "eventId": "evt_<id>",
        "tierId": "tier_<id>",
        "buyerEmail": "",
        "buyerName": "",
        "quantity": 1,
        "unitPriceCents": 1500,
        "totalCents": 1500,
        "promoCode": null,
        "discountCents": 0,
        "status": "pending | paid | free | refunded | cancelled",
        "stripeSessionId": null,
        "stripePaymentIntentId": null,
        "ticketIds": ["tkt_<id>"],
        "createdAt": "",
        "updatedAt": ""
      }
    },
    {
      "TableName": "nsmt-tickets",
      "BillingMode": "PAY_PER_REQUEST",
      "AttributeDefinitions": [
        { "AttributeName": "ticketId", "AttributeType": "S" },
        { "AttributeName": "eventId",  "AttributeType": "S" },
        { "AttributeName": "checkedIn","AttributeType": "S" }
      ],
      "KeySchema": [
        { "AttributeName": "ticketId", "KeyType": "HASH" },
        { "AttributeName": "eventId",  "KeyType": "RANGE" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "event-checkin-index",
          "KeySchema": [
            { "AttributeName": "eventId",   "KeyType": "HASH" },
            { "AttributeName": "checkedIn", "KeyType": "RANGE" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "Notes": "checkedIn is stored as string 'true'/'false' to work as GSI range key.",
      "ItemShape": {
        "ticketId": "tkt_<id>",
        "eventId": "evt_<id>",
        "orgId": "nsmt",
        "orderId": "ord_<id>",
        "tierId": "tier_<id>",
        "tierName": "General Admission",
        "buyerName": "",
        "buyerEmail": "",
        "checkedIn": "false",
        "checkedInAt": null,
        "checkedInBy": null
      }
    }
  ]
}
